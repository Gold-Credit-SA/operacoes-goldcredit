# ============================================================================
# Smart Scraper Worker — .env.example
# Copie para .env e preencha com os valores reais na VPS.
# NUNCA commit este arquivo preenchido.
# ============================================================================

# Porta do worker (interna; Nginx faz reverse proxy na 80/443).
PORT=4000

# Bearer token compartilhado com a edge function `smart-scraper`.
# Gere com: openssl rand -hex 32
WORKER_TOKEN=replace-with-a-strong-random-hex-string

# Credenciais do portal Smart (conta robô dedicada, NÃO conta pessoal).
SMART_PORTAL_URL=https://www.smartsecurities.com.br
SMART_PORTAL_USER=robo@goldcreditsa.com.br
SMART_PORTAL_PASS=change-me

# Pool de browsers (concorrência máxima de scrapes simultâneos).
# Recomendado 2-3. Cada chromium ~1 GB RAM.
SCRAPER_CONCURRENCY=2

# Timeout por scrape (ms). Acima disso retorna TIMEOUT.
SCRAPE_TIMEOUT_MS=30000

# Tempo (ms) que cookie de sessão persiste. Quando expira, força relogin.
SESSION_TTL_MS=1800000

# Diretório onde o Playwright salva o storage state (cookie).
# Útil pra fast-reboot — se o arquivo existe, reusa cookie sem relogar.
SESSION_STORAGE_PATH=./.playwright/session.json

# Modo headless. Em dev pode setar false pra ver o browser ao vivo.
HEADLESS=true

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Em dev, formata log com pino-pretty. Em prod deixe vazio (JSON estruturado).
NODE_ENV=production
