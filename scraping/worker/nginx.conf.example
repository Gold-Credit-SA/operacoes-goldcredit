# Nginx reverse proxy para o worker.
# Cole em /etc/nginx/sites-available/scraper.conf, ajuste o server_name e
# rode `certbot --nginx -d scraper.goldcreditcapital.com.br` pra Let's Encrypt.
#
# Depois: ln -s /etc/nginx/sites-available/scraper.conf /etc/nginx/sites-enabled/
# E: nginx -t && systemctl reload nginx

upstream smart_scraper {
    server 127.0.0.1:4000;
    keepalive 16;
}

# Bloco HTTP — redireciona pra HTTPS (Certbot adiciona automaticamente).
server {
    listen 80;
    server_name scraper.goldcreditcapital.com.br;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name scraper.goldcreditcapital.com.br;

    # Certbot preenche ssl_certificate / ssl_certificate_key.

    # Hardening básico.
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "no-referrer" always;

    # Limita tamanho de body (worker só recebe JSON pequeno).
    client_max_body_size 1m;

    # Timeout generoso pra acomodar scrape de até 30s.
    proxy_connect_timeout 10s;
    proxy_send_timeout 60s;
    proxy_read_timeout 60s;

    # IP allowlist (descomente e coloque o range de saída do Supabase).
    # Lookup em: https://supabase.com/docs/guides/platform/network-restrictions
    # allow 1.2.3.0/24;
    # deny  all;

    location /health {
        proxy_pass http://smart_scraper;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        access_log off;
    }

    location /scrape {
        proxy_pass http://smart_scraper;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
    }

    # Bloqueia qualquer outra rota.
    location / {
        return 404;
    }
}
