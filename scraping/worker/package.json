{
  "name": "smart-scraper-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Worker VPS para scraping de boleto/NF do portal Smart Securities. Invocado pela edge function smart-scraper.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "lint": "tsc --noEmit",
    "playwright:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "p-queue": "^8.0.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "playwright": "^1.49.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
